{
  "expo": {
    "name": "SpendWise",
    "slug": "spendwise",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spendwise",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lordjayanta.spendwise",
      "jsEngine": "hermes",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lordjayanta.spendwise",
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": true
          },
          "ios": {}
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Inter",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Inter_300Light_Italic.ttf",
                    "weight": 300,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_300Light.ttf",
                    "weight": 300,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Inter_400Regular_Italic.ttf",
                    "weight": 400,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_400Regular.ttf",
                    "weight": 400,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Inter_500Medium_Italic.ttf",
                    "weight": 500,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_500Medium.ttf",
                    "weight": 500,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Inter_600SemiBold_Italic.ttf",
                    "weight": 600,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_600SemiBold.ttf",
                    "weight": 600,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Inter_700Bold_Italic.ttf",
                    "weight": 700,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_700Bold.ttf",
                    "weight": 700,
                    "style": "normal"
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              {
                "fontFamily": "Inter",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Inter_300Light_Italic.ttf",
                    "weight": 300,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_300Light.ttf",
                    "weight": 300,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Inter_400Regular_Italic.ttf",
                    "weight": 400,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_400Regular.ttf",
                    "weight": 400,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Inter_500Medium_Italic.ttf",
                    "weight": 500,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_500Medium.ttf",
                    "weight": 500,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Inter_600SemiBold_Italic.ttf",
                    "weight": 600,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_600SemiBold.ttf",
                    "weight": 600,
                    "style": "normal"
                  },
                  {
                    "path": "./assets/fonts/Inter_700Bold_Italic.ttf",
                    "weight": 700,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_700Bold.ttf",
                    "weight": 700,
                    "style": "normal"
                  }
                ]
              }
            ]
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "22d2f83f-874c-4d59-8d9e-749daf243f6b"
      }
    }
  }
}
